# ============================================
# 动漫新闻自动抓取 & AI 筛选 & 飞书推送
# 配置文件模板 - 复制为 .env 并填入实际值
# ============================================

# ---------- AI API 配置 ----------
# 选择使用的 AI 提供商: gemini / openai
AI_PROVIDER=gemini

# Gemini API 配置
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- RSS 源配置 ----------
# 国外源（国内可能不稳定）
RSS_ANN=https://www.animenewsnetwork.com/all/rss.xml
RSS_CRUNCHYROLL=https://www.crunchyroll.com/news/rss

# RSSHub 镜像地址（国内推荐）
# 可用镜像: https://rsshub.rssforever.com | https://rsshub.pseudoyu.com | https://rsshub.fiveclaw.com
RSSHUB_BASE=https://rsshub.rssforever.com

# 是否启用 bgm.tv 热门讨论抓取 (true/false)
ENABLE_BGM=true
BGM_BASE_URL=https://bgm.tv

# ---------- 飞书推送配置 ----------
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token_here

# ---------- 微信公众号配置 ----------
WECHAT_APPID=your_appid_here
WECHAT_APPSECRET=your_appsecret_here

# ---------- 筛选阈值 ----------
# AI 评分高于此值的新闻才会被推送 (1-10)
SCORE_THRESHOLD=7

# ---------- 运行配置 ----------
# 定时模式下的抓取间隔（分钟）
INTERVAL_MINUTES=60
